# ─────────────────────────────────────────────────────────────
# Realship 评选平台 · 环境变量样例
# 复制为 .env 后按需填写。带「必填」的为最小可运行集合。
# ─────────────────────────────────────────────────────────────

# ── 数据库（PostgreSQL）· 必填 ────────────────────────────────
# DATABASE_URL：运行时连接（建议 pooled / pgbouncer）
# DIRECT_URL  ：迁移 / db push 用直连（unpooled）
# Neon 等连接串请勿带 channel_binding（Prisma 兼容性）。
# 自托管（docker compose --profile local-db）时指向内置库：
#   postgresql://real:real@db:5432/real
DATABASE_URL="postgresql://user:password@host/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ── Auth.js v5 · 必填 ─────────────────────────────────────────
# 生成：openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# ── 站点地址 · 生产必填 ───────────────────────────────────────
# 邮件链接（重置密码等）使用的绝对地址；必须是对外可访问的 URL。
APP_URL="http://localhost:3000"

# ── 文件存储 ──────────────────────────────────────────────────
# STORAGE_DRIVER：local（写入受保护 uploads/，需持久化卷）或 s3（推荐生产）。
STORAGE_DRIVER="local"
MAX_UPLOAD_MB="200"
# S3 兼容对象存储（STORAGE_DRIVER=s3 时必填；可对接 Cloudflare R2 / Backblaze B2 / MinIO）
S3_ENDPOINT=""
S3_REGION="auto"
S3_FORCE_PATH_STYLE="false"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""

# ── AI 审查（OpenAI 兼容端点）· 可选 ──────────────────────────
# 兼容 DeepSeek / 通义千问 / 智谱 GLM / OpenAI 等。
# 三者留空则「AI 提问式审查」整体禁用（不影响其余流程）。
AI_API_KEY=""
AI_BASE_URL="https://api.deepseek.com"
AI_MODEL="deepseek-chat"
# 多 agent 交叉评分（JSON 数组；填写后优先于上面单组，留空回退单组）
# AI_AGENTS='[{"apiKey":"sk-...","baseUrl":"https://api.deepseek.com","model":"deepseek-chat","label":"DeepSeek"}]'

# ── 邮件 SMTP · 可选（重置密码 / 注册验证码；留空则该功能降级禁用）──
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Realship <no-reply@example.com>"
# ─────────────────────────────────────────────────────────────
